{
  "name": "cockpitos",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:sw": "tsc src/serviceWorker.ts --outDir public --target ES2020 --lib ES2020,WebWorker --strict --skipLibCheck",
    "build": "npm run build:sw && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "android": "npm run build && npx cap sync android && npx cap open android",
    "cap:sync": "npm run build && npx cap sync",
    "cap:copy": "npm run build && npx cap copy",
    "guard": "vitest run src/__tests__/regression.guards.test.ts",
    "compat:verify": "node scripts/verify-webview-compat.mjs",
    "apk:safe": "npm run test && npm run build && npm run compat:verify && npx cap sync android && cd android && gradlew clean assembleDebug",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "vitest --config vitest.integration.config.ts",
    "test:all": "vitest run && vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "setup:e2e": "playwright install --with-deps chromium",
    "qa:oem:host": "node qa/index.mjs --profile host-only",
    "qa:oem:report": "node qa/index.mjs --render-only",
    "qa:oem:validate-profile": "node qa/index.mjs --validate-profile",
    "qa:oem:device-info": "node qa/device/index.mjs",
    "fetch:vosk": "node scripts/fetch-vosk-model.mjs",
    "release:bump": "node scripts/bump-version.mjs",
    "release:apk": "npm run build && npx cap sync android && cd android && gradlew assembleRelease",
    "release:aab": "npm run build && npx cap sync android && cd android && gradlew bundleRelease",
    "ota:publish": "node scripts/publish-ota.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/clipboard": "^8.0.1",
    "@capacitor/core": "^8.2.0",
    "@capacitor/filesystem": "^7.0.0",
    "@capacitor/geolocation": "^7.0.0",
    "@capacitor/network": "^8.0.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.104.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/three": "^0.185.1",
    "clsx": "^2.1.1",
    "i18next": "^26.3.5",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.577.0",
    "maplibre-gl": "^4.5.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.18.1",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.2.2",
    "three": "^0.185.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.13.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-legacy": "^8.1.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "regenerator-runtime": "^0.14.1",
    "terser": "^5.49.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.2"
  }
}
