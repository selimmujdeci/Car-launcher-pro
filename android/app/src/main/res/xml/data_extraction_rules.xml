<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ için Cloud Backup ve cihaz aktarımı kuralları -->
<data-extraction-rules>
    <cloud-backup>
        <include domain="sharedpref" path="cockpitos_recovery.xml"/>
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="cockpitos_recovery.xml"/>
    </device-transfer>
</data-extraction-rules>
